# direnv config. Loads a gitignored secret file holding the GitHub token for the
# `thatkevin` account, so `gh` and `git` act as that account inside this project
# without touching the global keyring.
#
# Set it up once:
#   echo 'export GH_TOKEN=ghp_yourTokenForThatkevin' > .env.local
#   direnv allow
#
# The token needs `repo` + `workflow` scopes. .env.local is gitignored.
dotenv_if_exists .env.local
